COMP_SQLITE_PATH=./data/vehicle_comps.db
FLASK_SECRET_KEY=change-me
SESSION_COOKIE_SECURE=true
CANONICAL_HOST=
TEST_ADMIN_EMAIL=admin@carflip.local
TEST_ADMIN_PASSWORD=admin12345

COMP_CACHE_TTL_SECONDS=1800
COMP_HTTP_TIMEOUT_SECONDS=20
COMP_HTTP_RETRY_COUNT=2
COMP_MAX_SOURCE_WORKERS=6
COMP_MAX_SOURCE_RESULTS=80
COMP_MAX_DETAIL_ENRICHMENT=18
COMP_MAX_VIN_DECODES=24

COMP_ENABLE_CRAIGSLIST=true
# These official adapters auto-enable when credentials are present.
# Leave the flags unset unless you want to force them on or off.
