# COMP_ENABLE_ONEAUTO=true
# COMP_ENABLE_EBAY_MOTORS=true
COMP_ENABLE_MARKETCHECK=false
# COMP_ENABLE_MARKETCHECK_DEALER=true
# COMP_ENABLE_MARKETCHECK_PRIVATE=false
COMP_ENABLE_MANUAL_IMPORT=true
COMP_ENABLE_CUSTOM_SOURCE=true

AUTODEV_API_KEY=
ONEAUTO_API_KEY=
OPENAI_API_KEY=
OPENAI_LINK_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_SOFTWARE_CHAT_MODEL=gpt-5.4
OPENAI_DETAILED_REPORT_MODEL=gpt-5.4-mini
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

BROWSER_AUTOMATION_PROVIDER=browser_use
BROWSER_USE_API_KEY=
